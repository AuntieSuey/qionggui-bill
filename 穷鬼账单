#!/bin/bash

# ============================================
# 穷鬼账单 - 一键启动脚本
# ============================================
#
# 使用方法：
#   1. 给脚本执行权限：chmod +x 穷鬼账单
#   2. 运行脚本：./穷鬼账单
#   3. 脚本会自动：
#      - CD 到项目目录
#      - 检测并处理端口冲突
#      - 启动 Expo 开发服务器
#      - 等待服务就绪
#      - 自动打开默认浏览器
#
# 停止服务：按 Ctrl+C
#
# ============================================

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 项目路径
PROJECT_DIR="/Users/admin/qionggui-bill"

# Expo 默认端口
EXPO_PORT=8081
EXPO_DEV_TOOLS_PORT=19001
EXPO_WEB_PORT=19006

# 日志函数
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# 检查端口占用
check_port() {
    local port=$1
    if lsof -Pi :$port -sTCP:LISTEN -t >/dev/null 2>&1; then
        local pid=$(lsof -ti:$port)
        local process=$(ps -p $pid -o comm=)
        return 0  # 端口被占用
    else
        return 1  # 端口空闲
    fi
}

# 杀死占用端口的进程
kill_process_on_port() {
    local port=$1
    if check_port $port; then
        local pid=$(lsof -ti:$port)
        log_warning "端口 $port 被进程 $pid 占用"
        kill -9 $pid 2>/dev/null
        sleep 1
        log_success "已释放端口 $port"
    fi
}

# 检查并清理 Node 进程
cleanup_node_processes() {
    log_info "检查并清理残留的 Node/Expo 进程..."

    # 查找项目目录下的 Node 进程
    local pids=$(pgrep -f "expo" | grep -v $$)
    if [ -n "$pids" ]; then
        log_warning "发现残留的 Expo 进程，正在清理..."
        echo "$pids" | xargs kill -9 2>/dev/null
        sleep 2
    fi

    # 清理端口占用
    kill_process_on_port $EXPO_PORT
    kill_process_on_port $EXPO_DEV_TOOLS_PORT
    kill_process_on_port $EXPO_WEB_PORT
}

# 检查项目文件
check_project() {
    if [ ! -d "$PROJECT_DIR" ]; then
        log_error "项目目录不存在: $PROJECT_DIR"
        exit 1
    fi

    if [ ! -f "$PROJECT_DIR/package.json" ]; then
        log_error "项目目录中缺少 package.json"
        exit 1
    fi

    if [ ! -f "$PROJECT_DIR/App.tsx" ]; then
        log_error "项目目录中缺少 App.tsx"
        exit 1
    fi
}

# 检查依赖
check_dependencies() {
    log_info "检查项目依赖..."

    if [ ! -d "$PROJECT_DIR/node_modules" ]; then
        log_warning "node_modules 不存在，正在安装依赖..."
        cd "$PROJECT_DIR"
        npm install
        if [ $? -ne 0 ]; then
            log_error "依赖安装失败"
            exit 1
        fi
        log_success "依赖安装完成"
    else
        log_success "依赖已安装"
    fi
}

# 启动 Expo
start_expo() {
    log_info "启动 Expo 开发服务器..."
    log_info "项目目录: $PROJECT_DIR"

    cd "$PROJECT_DIR" || exit 1

    # 清除缓存并启动
    log_info "使用 --clear 标志清除缓存..."
    npx expo start --clear --web --port $EXPO_PORT &
    EXPO_PID=$!

    # 等待 Expo 启动
    log_info "等待 Expo 服务器启动..."
    local max_wait=60
    local count=0
    local url=""

    while [ $count -lt $max_wait ]; do
        # 检查服务器是否响应
        if curl -s -o /dev/null -w "%{http_code}" "http://localhost:$EXPO_PORT" | grep -q "200"; then
            log_success "Expo 服务器已启动！"
            url="http://localhost:$EXPO_WEB_PORT"
            break
        fi

        # 检查进程是否还在运行
        if ! ps -p $EXPO_PID > /dev/null 2>&1; then
            log_error "Expo 启动失败，进程已退出"
            exit 1
        fi

        sleep 2
        count=$((count + 1))

        # 每10秒输出一次等待信息
        if [ $((count % 5)) -eq 0 ]; then
            log_info "等待中... ($count/$max_wait 秒)"
        fi
    done

    if [ -z "$url" ]; then
        log_error "Expo 启动超时（${max_wait}秒）"
        kill $EXPO_PID 2>/dev/null
        exit 1
    fi

    # 额外等待确保完全就绪
    sleep 3

    # 打开浏览器
    log_info "正在打开浏览器: $url"
    if open "$url" 2>/dev/null; then
        log_success "浏览���已打开！"
    else
        log_warning "无法自动打开浏览器，请手动访问: $url"
    fi

    # 显示二维码信息
    log_info "=========================================="
    log_success "穷鬼账单已启动！"
    log_info "Web 地址: $url"
    log_info "二维码: 使用 Expo Go 扫描"
    log_info "按 Ctrl+C 停止服务器"
    log_info "=========================================="

    # 保持脚本运行
    wait $EXPO_PID
}

# 主函数
main() {
    echo "=========================================="
    echo "  穷鬼账单 - 一键启动脚本"
    echo "=========================================="
    echo ""

    # 1. 检查项目
    log_info "步骤 1/4: 检查项目文件..."
    check_project

    # 2. 清理残留进程
    log_info "步骤 2/4: 清理残留进程和端口..."
    cleanup_node_processes

    # 3. 检查依赖
    log_info "步骤 3/4: 检查项目依赖..."
    check_dependencies

    # 4. 启动服务
    log_info "步骤 4/4: 启动服务..."
    start_expo
}

# 捕获 Ctrl+C
trap 'log_warning "正在停止服务器..."; kill $EXPO_PID 2>/dev/null; exit 0' INT TERM

# 运行主函数
main
